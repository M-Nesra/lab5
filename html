<html>
  <head>
    <title>INST377 Lab 5</title>
    <script defer src="Currency.js"></script>
    <style>
      body {
      background-color: #d7b8f3;
      font-family: serif;
      padding: 20px;
      }
    </style>
  </head>
  <body>
    <h1>Let's Convert some Currency!</h1>
    <form onsubmit="convertCurrency(); return false;">
      <label for="fromCurrency">From Currency: </label>
      <select id="fromCurrency">
      </select>
      <br>
      <label for="toCurrency">To Currency: </label>
      <select id="toCurrency">
      </select>
      <br>
      <label for="amount">Number to Convert: </label>
      <input type="number" id="amount" step="any" required>
      <br>
      <input type="submit">
    </form>
    <h2 id="result"></h2>
  </body>
</html>
